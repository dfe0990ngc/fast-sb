{
  "autoload": {
    "psr-4": {
      "App\\": "./"
    }
  },
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-pdo": "*",
    "aws/aws-sdk-php": "^3.374",
    "firebase/php-jwt": "^6.10",
    "ifsnop/mysqldump-php": "^2.12",
    "mpdf/mpdf": "^8.2",
    "phpoffice/phpspreadsheet": "^5.5",
    "predis/predis": "^2.2",
    "vlucas/phpdotenv": "^5.6"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
